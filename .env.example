# Used ONLY by `docker-compose up` — separate from backend/.env and
# frontend/.env, which are used when running `npm run dev` directly.
#
# Copy this to `.env` (same folder as docker-compose.yml) and fill in
# real values. This root .env is already covered by .gitignore.

DATABASE_URL=postgresql://postgres:fSOuLLzUJgwHUBJRKvJuIKbYUEbMYYPk@reseau.proxy.rlwy.net:24760/railway

JWT_SECRET=generate_a_separate_one_with_openssl_rand_hex_32

# --- Gmail API (for magic-link emails) ---
GMAIL_CLIENT_ID=your_client_id_from_google_cloud_console
GMAIL_CLIENT_SECRET=your_client_secret_from_google_cloud_console
GMAIL_REFRESH_TOKEN=generate_with_npm_run_get-gmail-token
GMAIL_SENDER_EMAIL=youraddress@gmail.com

# Leave these two as their defaults unless you've changed the published
# ports in docker-compose.yml (backend :3001, frontend/nginx :80)
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost

TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_BOT_USERNAME=your_bot_username_without_at_sign
TELEGRAM_WEBHOOK_SECRET=optional_shared_secret_you_choose

CLEANUP_STALE_DAYS=3
CLEANUP_CRON_EXPRESSION=0 3 * * *

# Baked into the frontend image at build time (Vite requirement).
# Must be reachable from your BROWSER, not the container network —
# with the backend published on host port 3001, localhost:3001 is correct.
VITE_API_BASE_URL=http://localhost:3001/api